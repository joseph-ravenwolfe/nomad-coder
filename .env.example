# Telegram Bridge MCP — Environment Configuration
# Copy this file to .env and fill in your values.
# Or run `pnpm pair` to auto-fill BOT_TOKEN, ALLOWED_USER_ID, and ALLOWED_CHAT_ID.

# ── Required ──────────────────────────────────────────────────────────────────
# Get your token from @BotFather on Telegram. Never commit this to version control.
BOT_TOKEN=

# ── Security (STRONGLY recommended) ──────────────────────────────────────────
# Your numeric Telegram user ID (find it via Step 3 in SETUP.md or run pnpm pair).
# When set, ALL inbound updates from any other sender are silently discarded.
# Without this, anyone who discovers your bot's @username can inject messages.
ALLOWED_USER_ID=

# The chat ID this bot is allowed to operate in.
# When set, both inbound updates from other chats AND outbound sends to other
# chats are rejected before touching the Telegram API.
# Use your personal DM chat ID for solo use, or a group/channel ID for teams.
ALLOWED_CHAT_ID=

# ── Voice transcription (optional) ───────────────────────────────────────────
# Hugging Face model ID for local Whisper transcription.
# Smaller/faster: onnx-community/whisper-tiny
# Default:        onnx-community/whisper-base
# More accurate:  onnx-community/whisper-small
# WHISPER_MODEL=onnx-community/whisper-base

# Directory to cache downloaded model weights.
# Default: uses the HuggingFace global cache (~/.cache/huggingface).
# WHISPER_CACHE_DIR=/path/to/cache

# ── Text-to-speech (optional) ────────────────────────────────────────────────
# Point at any OpenAI-compatible TTS server (e.g. Chatterbox, Kokoro via a local server).
# If unset, falls back to OPENAI_API_KEY, then to the free local ONNX model.
# TTS_HOST=http://your-tts-server

# Model and voice to request from the TTS server (both optional).
# TTS_MODEL=chatterbox
# TTS_VOICE=default

# Response format to request. Default: wav (decoded locally to OGG/Opus).
# Set to opus or ogg if your server can return OGG/Opus natively — skips
# the local decode+re-encode step entirely.
# TTS_FORMAT=opus

# ── TTS: OpenAI API ───────────────────────────────────────────────────────────
# Set OPENAI_API_KEY (and no TTS_HOST) to use api.openai.com.
# OPENAI_API_KEY=sk-...
# TTS_MODEL=tts-1          # or tts-1-hd
# TTS_VOICE=alloy          # alloy/echo/fable/onyx/nova/shimmer

# ── TTS: local ONNX provider (default fallback) ───────────────────────────────
# HuggingFace model ID for the local ONNX TTS engine.
# Default: Xenova/mms-tts-eng
# TTS_MODEL_LOCAL=Xenova/mms-tts-eng
# TTS_CACHE_DIR=/path/to/cache
