# Telegram Bridge MCP — Environment Configuration
# Copy this file to .env and fill in your values.
# Or run `pnpm pair` to auto-fill BOT_TOKEN and ALLOWED_USER_ID.

# ── Required ──────────────────────────────────────────────────────────────────
# Get your token from @BotFather on Telegram. Never commit this to version control.
BOT_TOKEN=

# ── Security (STRONGLY recommended) ──────────────────────────────────────────
# Your numeric Telegram user ID (find it via Step 3 in setup.md or run pnpm pair).
# When set, ALL inbound updates from any other sender are silently discarded.
# Without this, anyone who discovers your bot's @username can inject messages.
ALLOWED_USER_ID=

# ── Transport (optional) ────────────────────────────────────────────────────
# Set to enable Streamable HTTP transport on this port instead of stdio.
# Run one server instance and connect any number of MCP clients to it.
# MCP_PORT=3099


# ── Voice transcription (optional) ───────────────────────────────────────────
# Point at any OpenAI-compatible Whisper server (e.g. faster-whisper-server).
# If set, audio is forwarded as-is — no local decode or model required.
# STT_HOST=http://your-whisper-server

# Model to request from the remote server (default: whisper-1).
# Also selects the local ONNX model when STT_HOST is not set.
# Remote default: whisper-1
# Local options:  onnx-community/whisper-tiny (fast)
#                 onnx-community/whisper-base (default)
#                 onnx-community/whisper-small (accurate)
# WHISPER_MODEL=whisper-1

# Directory to cache downloaded local model weights.
# Default: uses the HuggingFace global cache (~/.cache/huggingface).
# WHISPER_CACHE_DIR=/path/to/cache

# ── Text-to-speech (optional) ────────────────────────────────────────────────
# Point at any OpenAI-compatible TTS server.
# If unset, falls back to OPENAI_API_KEY, then to the free local ONNX model.
# TTS_HOST=http://your-tts-server

# Model and voice to request from the TTS server (both optional).
# TTS_MODEL=chatterbox
# TTS_VOICE=default

# Response format to request. Default: wav (decoded locally to OGG/Opus).
# Set to opus or ogg if your server can return OGG/Opus natively — skips
# the local decode+re-encode step entirely.
# TTS_FORMAT=opus

# ── TTS: Kokoro example ───────────────────────────────────────────────────────
# If running a Kokoro server, include the base path in TTS_HOST:
# TTS_HOST=http://your-kokoro-server/kokoro
# TTS_FORMAT=ogg
# TTS_VOICE=af_heart
# Voices — Female (American): af_heart af_bella af_nicole af_sarah
#         — Male   (American): am_adam am_michael am_echo am_liam
#         — Female (British):  bf_emma bf_isabella
#         — Male   (British):  bm_george bm_lewis

# ── TTS: OpenAI API ───────────────────────────────────────────────────────────
# Set OPENAI_API_KEY (and no TTS_HOST) to use api.openai.com.
# OPENAI_API_KEY=sk-...
# TTS_MODEL=tts-1          # or tts-1-hd
# TTS_VOICE=alloy          # alloy/echo/fable/onyx/nova/shimmer

# ── TTS: local ONNX provider (default fallback) ───────────────────────────────
# HuggingFace model ID for the local ONNX TTS engine.
# Default: Xenova/mms-tts-eng
# TTS_MODEL_LOCAL=Xenova/mms-tts-eng
# TTS_CACHE_DIR=/path/to/cache
