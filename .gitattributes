# Set default behavior — Git still auto-detects binary vs text
* text=auto eol=lf

# Source files — LF everywhere
*.ts   text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.sh   text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf

# Windows scripts — CRLF
*.ps1  text eol=crlf
*.cmd  text eol=crlf
*.bat  text eol=crlf
