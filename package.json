{
  "name": "telegram-bridge-mcp",
  "author": {
    "name": "electricessence"
  },
  "version": "1.7.6",
  "description": "Telegram Bridge MCP — An MCP server that bridges AI assistants to a Telegram bot for two-way messaging, confirmations, status updates, and voice transcription.",
  "license": "MIT",
  "homepage": "https://github.com/electricessence/Telegram-Bridge-MCP",
  "repository": {
    "type": "git",
    "url": "https://github.com/electricessence/Telegram-Bridge-MCP.git"
  },
  "keywords": [
    "mcp",
    "telegram",
    "bot",
    "bridge",
    "ai",
    "llm",
    "copilot",
    "claude",
    "model-context-protocol"
  ],
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "pair": "node dist/setup.js",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ]
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "audio-decode": "^2.2.3",
    "dotenv": "^16.4.5",
    "grammy": "^1.40.0",
    "opusscript": "^0.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.5.4",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.0.0"
}
