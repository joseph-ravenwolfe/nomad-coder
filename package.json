{
  "name": "telegram-bridge-mcp",
  "author": {
    "name": "electricessence"
  },
  "version": "3.0.0",
  "description": "Telegram Bridge MCP — An MCP server that bridges AI assistants to a Telegram bot for two-way messaging, confirmations, status updates, and voice transcription.",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/electricessence/Telegram-Bridge-MCP",
  "repository": {
    "type": "git",
    "url": "https://github.com/electricessence/Telegram-Bridge-MCP.git"
  },
  "keywords": [
    "mcp",
    "telegram",
    "bot",
    "bridge",
    "ai",
    "llm",
    "copilot",
    "claude",
    "model-context-protocol"
  ],
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "build": "tsc && node scripts/gen-build-info.mjs",
    "typecheck": "tsc --noEmit",
    "pair": "node dist/setup.js",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "coverage": "vitest run --coverage"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ]
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "audio-decode": "^2.2.3",
    "dotenv": "^17.3.1",
    "grammy": "^1.40.1",
    "opusscript": "^0.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.0.0"
}
