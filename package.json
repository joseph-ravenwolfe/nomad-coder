{
  "name": "nomad-coder",
  "author": {
    "name": "Joseph Ravenwolfe"
  },
  "version": "8.0.0",
  "description": "Nomad Coder — An MCP server that bridges AI assistants to a Telegram bot for two-way messaging, confirmations, status updates, and voice transcription.",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/joseph-ravenwolfe/nomad-coder",
  "repository": {
    "type": "git",
    "url": "https://github.com/joseph-ravenwolfe/nomad-coder.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "telegram",
    "bot",
    "bridge",
    "ai",
    "llm",
    "agent",
    "multi-agent",
    "copilot",
    "github-copilot",
    "claude",
    "claude-code",
    "cursor",
    "vscode",
    "openai",
    "ollama",
    "platform-agnostic",
    "multi-platform",
    "streamable-http",
    "voice",
    "multi-session"
  ],
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "build": "tsc && node scripts/gen-build-info.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.eslint.json",
    "pair": "node dist/setup.js",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "tsc --noEmit -p tsconfig.eslint.json && vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "coverage": "vitest run --coverage"
  },
  "overrides": {
    "flatted": "3.4.2",
    "picomatch": "4.0.4",
    "brace-expansion": "5.0.5",
    "path-to-regexp": "8.4.0",
    "vite": "7.3.2",
    "hono": "4.12.14",
    "@hono/node-server": "1.19.13",
    "protobufjs": "7.5.5"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@tsdotnet/queue": "^1.3.2",
    "audio-decode": "^3.5.0",
    "dotenv": "^17.3.1",
    "grammy": "^1.42.0",
    "opusscript": "^0.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.0"
  }
}
